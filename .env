# ─── VoiceShifter Configuration ───────────────────────────────────────────────

# Your ElevenLabs API key
# Get it from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_57b168981e543c3af2d84776b17e6462aaa6d5cc3498d623

# Your trained voice ID
# Go to: https://elevenlabs.io/app/voice-lab → click your voice → copy the ID
VOICE_ID=xdk4JesMU7XcMrJnv3W2

# Seconds of audio per conversion chunk (lower = less delay, more API calls)
# Recommended: 2 or 3
CHUNK_SECONDS=3

# Output device — must match VB-Cable playback device name in Windows Sound settings
# Default is "CABLE Input" — only change if yours is named differently
OUTPUT_DEVICE=CABLE Input

# Input device — leave blank for auto-detect
# If auto-detect picks the wrong mic, run:
#   ffmpeg.exe -list_devices true -f dshow -i dummy
# Then paste your mic name here, e.g:
#   INPUT_DEVICE=Microphone (Realtek Audio)
INPUT_DEVICE=
